    {
      "name": "Participation",
      "item": [
        {
          "name": "Start Contest",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Start contest request succeeded\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "if (json && json.success && json.data && Array.isArray(json.data.questions)) {",
                  "    var questions = json.data.questions;",
                  "",
                  "    pm.collectionVariables.unset(\"question1Id\");",
                  "    pm.collectionVariables.unset(\"question2Id\");",
                  "    pm.collectionVariables.unset(\"question3Id\");",
                  "    pm.collectionVariables.unset(\"question1Option1Id\");",
                  "    pm.collectionVariables.unset(\"question1Option2Id\");",
                  "    pm.collectionVariables.unset(\"question1Option3Id\");",
                  "    pm.collectionVariables.unset(\"question1Option4Id\");",
                  "    pm.collectionVariables.unset(\"question2Option1Id\");",
                  "    pm.collectionVariables.unset(\"question2Option2Id\");",
                  "    pm.collectionVariables.unset(\"question2Option3Id\");",
                  "    pm.collectionVariables.unset(\"question2Option4Id\");",
                  "",
                  "    questions.forEach(function (question, index) {",
                  "        var questionIndex = index + 1;",
                  "        pm.collectionVariables.set(\"question\" + questionIndex + \"Id\", question.id || \"\");",
                  "",
                  "        if (Array.isArray(question.options)) {",
                  "            question.options.forEach(function (option, optionIndex) {",
                  "                pm.collectionVariables.set(",
                  "                    \"question\" + questionIndex + \"Option\" + (optionIndex + 1) + \"Id\",",
                  "                    option.id || \"\"",
                  "                );",
                  "            });",
                  "        }",
                  "    });",
                  "",
                  "    if (questions.length > 0) {",
                  "        pm.collectionVariables.set(\"questionId\", questions[0].id || \"\");",
                  "    }",
                  "",
                  "    console.log(\"Stored\", questions.length, \"question ids in collection variables.\");",
                  "}",
                  "",
                  "pm.test(\"Question ids captured\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.questions.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
